{
  "name": "pi-autodev",
  "version": "0.1.0",
  "type": "module",
  "description": "Autonomous pi extension: idea \u2192 plan \u2192 build \u2192 verify \u2192 ship",
  "main": "dist/extension/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "js-yaml": "^4.1.2"
  },
  "files": [
    "dist/**/*",
    "skills/**/*",
    "package.json",
    "install.mjs"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "autodev",
    "autonomous",
    "build-pipeline"
  ],
  "pi": {
    "extensions": ["./dist/extension/index.js"],
    "skills": ["./skills"]
  }
}
